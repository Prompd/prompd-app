{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Prompd",
  "patterns": [
    { "include": "#frontmatter" },
    { "include": "#markdown" }
  ],
  "repository": {
    "frontmatter": {
      "begin": "^(---)\\s*$",
      "end": "^(---)\\s*$",
      "name": "meta.frontmatter.prompd",
      "beginCaptures": { "1": { "name": "punctuation.definition.frontmatter.begin.prompd" } },
      "endCaptures": { "1": { "name": "punctuation.definition.frontmatter.end.prompd" } },
      "patterns": [
        { "include": "#yaml-content" },
        { "include": "source.yaml" }
      ]
    },
    "yaml-content": {
      "patterns": [
        {
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_-]*)\\s*(:)\\s*(.*)$",
          "captures": {
            "1": { "name": "entity.name.tag.yaml" },
            "2": { "name": "punctuation.separator.key-value.yaml" },
            "3": { "patterns": [
              { "include": "#yaml-value" }
            ]}
          }
        },
        {
          "match": "^\\s*(-\\s+)([a-zA-Z_][a-zA-Z0-9_-]*)\\s*(:)\\s*(.*)$",
          "captures": {
            "1": { "name": "punctuation.definition.list.yaml" },
            "2": { "name": "entity.name.tag.yaml" },
            "3": { "name": "punctuation.separator.key-value.yaml" },
            "4": { "patterns": [
              { "include": "#yaml-value" }
            ]}
          }
        }
      ]
    },
    "yaml-value": {
      "patterns": [
        { "match": "\\btrue\\b|\\bfalse\\b", "name": "constant.language.boolean.yaml" },
        { "match": "\\b[0-9]+(\\.[0-9]+)?\\b", "name": "constant.numeric.yaml" },
        { "match": "\"[^\"]*\"", "name": "string.quoted.double.yaml" },
        { "match": "'[^']*'", "name": "string.quoted.single.yaml" },
        { "match": "[^\\s#]+", "name": "string.unquoted.yaml" }
      ]
    },
    "markdown": {
      "patterns": [
        { "include": "#heading" },
        { "include": "#codeblock" },
        { "include": "#variable" },
        { "include": "#jinja" },
        { "include": "#emphasis" },
        { "include": "#lists" },
        { "include": "text.html.markdown" }
      ]
    },
    "heading": {
      "patterns": [
        {
          "match": "^(#{1,6})\\s+(System|Context|User|Response|Assistant)\\s*$",
          "name": "markup.heading.section.prompd",
          "captures": {
            "1": { "name": "punctuation.definition.heading.prompd" },
            "2": { "name": "entity.name.section.prompd" }
          }
        },
        {
          "match": "^(#{1,6})\\s+(.+)$",
          "name": "markup.heading.prompd",
          "captures": {
            "1": { "name": "punctuation.definition.heading.prompd" },
            "2": { "name": "entity.name.heading.prompd" }
          }
        }
      ]
    },
    "variable": {
      "patterns": [
        {
          "match": "\\{\\{([a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)*)\\}\\}",
          "name": "variable.other.template.prompd",
          "captures": {
            "0": { "name": "punctuation.definition.variable.begin.prompd punctuation.definition.variable.end.prompd" },
            "1": { "name": "variable.name.prompd" }
          }
        },
        {
          "match": "\\{([a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)*)\\}",
          "name": "variable.other.simple.prompd",
          "captures": {
            "0": { "name": "punctuation.definition.variable.prompd" },
            "1": { "name": "variable.name.prompd" }
          }
        }
      ]
    },
    "jinja": {
      "patterns": [
        { "begin": "\\{%", "end": "%\\}", "name": "meta.embedded.jinja.prompd", "patterns": [ { "match": "\\b(if|elif|else|endif|for|endfor|set|include)\\b", "name": "keyword.control.jinja.prompd" } ] },
        { "begin": "\\{#", "end": "#\\}", "name": "comment.block.jinja.prompd" }
      ]
    },
    "codeblock": {
      "patterns": [
        {
          "begin": "^(\\s*)(```|~~~)\\s*([a-zA-Z0-9_+-]*)?\\s$",
          "end": "^(\\s*)(\\2)\\s$",
          "name": "markup.fenced_code.block.prompd",
          "beginCaptures": { "2": { "name": "punctuation.definition.fenced.prompd" }, "3": { "name": "fenced_code.block.language.prompd" } },
          "endCaptures": { "2": { "name": "punctuation.definition.fenced.prompd" } },
          "patterns": [ { "include": "source.js" }, { "include": "source.python" }, { "include": "source.typescript" } ]
        },
        {
          "match": "(`+)([^`]*)(\\1)",
          "name": "markup.inline.raw.prompd",
          "captures": {
            "1": { "name": "punctuation.definition.raw.prompd" },
            "2": { "name": "markup.inline.raw.string.prompd" },
            "3": { "name": "punctuation.definition.raw.prompd" }
          }
        }
      ]
    },
    "emphasis": {
      "patterns": [
        { "match": "(\\*\\*|__)([^\\*_]+)(\\1)", "name": "markup.bold.prompd", "captures": { "1": { "name": "punctuation.definition.bold.prompd" }, "2": { "name": "markup.bold.text.prompd" }, "3": { "name": "punctuation.definition.bold.prompd" } } },
        { "match": "(\\*|_)([^\\*_]+)(\\1)", "name": "markup.italic.prompd", "captures": { "1": { "name": "punctuation.definition.italic.prompd" }, "2": { "name": "markup.italic.text.prompd" }, "3": { "name": "punctuation.definition.italic.prompd" } } }
      ]
    },
    "lists": {
      "patterns": [
        { "match": "^\\s*([\\*\\+\\-])\\s+", "name": "markup.list.unnumbered.prompd", "captures": { "1": { "name": "punctuation.definition.list_item.prompd" } } },
        { "match": "^\\s*([0-9]+\\.)\\s+", "name": "markup.list.numbered.prompd", "captures": { "1": { "name": "punctuation.definition.list_item.prompd" } } }
      ]
    }
  },
  "scopeName": "source.prompd"
}

